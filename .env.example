LLM_MODEL=moonshot-v1-32k

# ===== App =====
MONITOR_INTERVAL=60
SUMMARY_MAX_LENGTH=500
COMMENT_SEND_INTERVAL=30
SUBTITLE_MAX_LENGTH=15000

# ===== Database =====
DATABASE_URL=sqlite+aiosqlite:///./biliagent.db
