# ===== Bilibili =====
BILI_SESSDATA=your_sessdata_here
BILI_BILI_JCT=your_bili_jct_here
BILI_BUVID3=your_buvid3_here
BILI_ACCOUNT_UID=your_uid_here

# ===== LLM (Kimi 2.5 / Moonshot) =====
LLM_API_KEY=your_moonshot_api_key_here
